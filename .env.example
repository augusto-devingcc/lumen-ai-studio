# Lumen — variables de entorno
# Copia este archivo a .env.local y rellena las keys que tengas.
# La app CORRE SIN KEYS: el provider layer cae a un mock con assets de placeholder.

# --- Chat (Vercel AI SDK) ---
# Sin esta key, el Chat responde con un aviso de que falta configurar Anthropic.
ANTHROPIC_API_KEY=

# --- Generación de imagen / video (principal) ---
# https://fal.ai/dashboard/keys
FAL_KEY=

# --- Generación (fallback cuando Fal no tiene el modelo o falla) ---
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- Audio / voz (TTS) ---
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# --- Opcional: fuerza el provider mock aunque haya keys (útil para demo/CI) ---
# LUMEN_FORCE_MOCK=1
